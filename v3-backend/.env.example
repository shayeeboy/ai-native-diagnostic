# Copy this file to .env for local development.
# NEVER commit the real .env file — it's already in .gitignore.
#
# On Render, set these as Environment Variables in the dashboard instead
# of uploading a .env file.

# Connection string from Neon (or any Postgres provider).
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Port the API listens on. Render sets this automatically in production —
# this default is only used for local dev.
PORT=3000

# Comma-separated list of origins allowed to call this API.
# Add your Carrd site's URL(s) here once you know them, e.g.:
# ALLOWED_ORIGINS=https://yourproject.carrd.co,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500
